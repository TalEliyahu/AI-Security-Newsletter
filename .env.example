TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_CHANNEL=@AISecHub

# Optional: comma-separated Telegram user ids allowed to send channel posts
# through private bot commands. Send /whoami to the bot to find your id.
TELEGRAM_ALLOWED_USER_IDS=

# Optional webhook settings, used when running behind a public HTTPS URL.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
PORT=8787

